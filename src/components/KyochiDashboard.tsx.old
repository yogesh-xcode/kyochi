            {/* Therapist Table */}
            <Card>
              <div style={{ padding: "20px 24px 0" }}>
                <div
                  style={{
                    display: "flex",
                    justifyContent: "space-between",
                    alignItems: "center",
                    marginBottom: 16,
                  }}
                >
                  <p style={{ fontSize: 14, fontWeight: 700, color: T.text }}>
                    Therapist Performance
                  </p>
                  <button
                    style={{
                      display: "flex",
                      alignItems: "center",
                      gap: 4,
                      fontSize: 12,
                      fontWeight: 700,
                      color: T.gold500,
                      background: "none",
                      border: "none",
                      cursor: "pointer",
                      fontFamily: "inherit",
                    }}
                  >
                    See all <ArrowRight size={13} />
                  </button>
                </div>
              </div>

              {/* Table */}
              <div style={{ overflowX: "auto" }}>
                <table style={{ width: "100%", borderCollapse: "collapse" }}>
                  <thead>
                    <tr
                      style={{
                        borderTop: `1px solid ${T.border}`,
                        borderBottom: `1px solid ${T.border}`,
                        background: T.cream100,
                      }}
                    >
                      {["Therapist", "Sessions", "Rating", "Status", "Load"].map((h) => (
                        <th
                          key={h}
                          style={{
                            padding: "10px 20px",
                            textAlign: "left",
                            fontSize: 10,
                            fontWeight: 700,
                            letterSpacing: "0.07em",
                            textTransform: "uppercase",
                            color: T.textFaint,
                            whiteSpace: "nowrap",
                          }}
                        >
                          {h}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {therapists.map((t, i) => (
                      <tr
                        key={t.name}
                        style={{
                          borderBottom: i < therapists.length - 1 ? `1px solid ${T.border}` : "none",
                          transition: "background 0.15s ease",
                        }}
                      >
                        <td style={{ padding: "14px 20px" }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                            <Avatar initials={t.initials} size="sm" gold />
                            <div>
                              <p style={{ fontSize: 13, fontWeight: 700, color: T.text }}>
                                {t.name}
                              </p>
                              <p style={{ fontSize: 11, color: T.textFaint }}>{t.speciality}</p>
                            </div>
                          </div>
                        </td>
                        <td style={{ padding: "14px 20px", fontSize: 14, fontWeight: 700, color: T.text }}>
                          {t.sessions}
                        </td>
                        <td style={{ padding: "14px 20px" }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 4 }}>
                            <Star size={12} style={{ color: T.gold400, fill: T.gold400 }} />
                            <span style={{ fontSize: 13, fontWeight: 700, color: T.text }}>
                              {t.rating}
                            </span>
                          </div>
                        </td>
                        <td style={{ padding: "14px 20px" }}>
                          <Badge tone={t.status === "In Session" ? "session" : "positive"}>
                            {t.status}
                          </Badge>
                        </td>
                        <td style={{ padding: "14px 20px" }}>
                          <div style={{ width: 80 }}>
                            <div
                              style={{
                                display: "flex",
                                justifyContent: "space-between",
                                marginBottom: 4,
                              }}
                            >
                              <span style={{ fontSize: 10, fontWeight: 700, color: T.textFaint }}>
                                {t.load}%
                              </span>
                            </div>
                            <ProgressBar
                              value={t.load}
                              color={t.load > 80 ? T.gold400 : T.green400}
                              color2={t.load > 80 ? T.gold300 : "#72be8a"}
                              height={5}
                            />
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </Card>

            {/* Right column: Appointments + Wellness Rings */}
            <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>

              {/* Recent Appointments */}
              <Card>
                <div style={{ padding: "20px 20px 16px" }}>
                  <p style={{ fontSize: 14, fontWeight: 700, color: T.text, marginBottom: 14 }}>
                    Recent Appointments
                  </p>
                  <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                    {recentAppointments.map((appt) => (
                      <div
                        key={appt.patient}
                        style={{
                          display: "flex",
                          alignItems: "center",
                          gap: 10,
                          padding: "10px 12px",
                          background: T.cream100,
                          border: `1px solid ${T.border}`,
                          borderRadius: 12,
                        }}
                      >
                        <DotIndicator tone={appt.tone} />
                        <div style={{ flex: 1, minWidth: 0 }}>
                          <p
                            style={{
                              fontSize: 12,
                              fontWeight: 700,
                              color: T.text,
                              whiteSpace: "nowrap",
                              overflow: "hidden",
                              textOverflow: "ellipsis",
                            }}
                          >
                            {appt.patient}
                          </p>
                          <p style={{ fontSize: 10, color: T.textFaint }}>{appt.therapy}</p>
                        </div>
                        <div
                          style={{
                            display: "flex",
                            alignItems: "center",
                            gap: 4,
                            color: T.textFaint,
                          }}
                        >
                          <Clock size={10} />
                          <span style={{ fontSize: 10, fontWeight: 600 }}>{appt.time}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </Card>

              {/* Wellness Rings */}
              <Card>
                <div style={{ padding: "20px" }}>
                  <p style={{ fontSize: 14, fontWeight: 700, color: T.text, marginBottom: 4 }}>
                    Wellness Scores
                  </p>
                  <p style={{ fontSize: 11, color: T.textFaint, marginBottom: 16 }}>
                    Avg across today's sessions
                  </p>
                  <div style={{ display: "flex", justifyContent: "space-around" }}>
                    <WellnessRing value={7.8} color={T.gold400} label="Overall" />
                    <WellnessRing value={8.6} color={T.green400} label="Post-session" />
                    <WellnessRing value={4.2} color={T.red400} label="Stress" max={10} />
                  </div>
                  <div
                    style={{
                      display: "flex",
                      justifyContent: "space-around",
                      marginTop: 8,
                    }}
                  >
                    <span style={{ fontSize: 10, fontWeight: 700, color: T.textFaint }}>Current</span>
                    <span style={{ fontSize: 10, fontWeight: 700, color: T.green400 }}>▲ +0.8</span>
                    <span style={{ fontSize: 10, fontWeight: 700, color: T.textFaint }}>Before</span>
                  </div>
                </div>
              </Card>
            </div>
          </div>

          {/* AI Insight Banner */}
          <div
            style={{
              background: "linear-gradient(135deg, #241e15 0%, #3d2d04 60%, #5c4507 100%)",
              border: "1px solid rgba(212,175,53,0.28)",
              borderRadius: 20,
              padding: "22px 28px",
              boxShadow: T.shadowGold,
              display: "flex",
              alignItems: "center",
              gap: 20,
              flexWrap: "wrap",
            }}
          >
            <div
              style={{
                width: 40,
                height: 40,
                borderRadius: 12,
                background: "rgba(212,175,53,0.18)",
                border: "1px solid rgba(212,175,53,0.35)",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                flexShrink: 0,
                fontSize: 18,
              }}
            >
              ✦
            </div>
            <div style={{ flex: 1, minWidth: 240 }}>
              <p
                style={{
                  fontSize: 9,
                  fontWeight: 700,
                  letterSpacing: "0.12em",
                  textTransform: "uppercase",
                  color: T.gold300,
                  marginBottom: 5,
                }}
              >
                AI Insight · Powered by Claude
              </p>
              <p style={{ fontSize: 13, color: T.gold100, lineHeight: 1.65 }}>
                Stress relief outcomes are strongest for{" "}
                <strong style={{ color: T.gold300 }}>Relaxation</strong> therapy in repeat patients
                this week. Consider scheduling a follow-up touchpoint after session 3 to improve
                retention.
              </p>
            </div>
            <div style={{ display: "flex", gap: 8, flexShrink: 0 }}>
              <button
                style={{
                  padding: "8px 18px",
                  borderRadius: 10,
                  border: "none",
                  background: T.gold400,
                  color: T.gold900,
                  fontSize: 12,
                  fontWeight: 700,
                  fontFamily: "inherit",
                  cursor: "pointer",
                  boxShadow: "0 2px 10px rgba(212,175,53,0.4)",
                }}
              >
                View Details
              </button>
              <button
                style={{
                  padding: "8px 18px",
                  borderRadius: 10,
                  border: "1px solid rgba(255,255,255,0.15)",
                  background: "rgba(255,255,255,0.08)",
                  color: T.gold200,
                  fontSize: 12,
                  fontWeight: 700,
                  fontFamily: "inherit",
                  cursor: "pointer",
                }}
              >
                Refresh
              </button>
            </div>
          </div>

        </div>
      </div>
    </div>
  );
}
