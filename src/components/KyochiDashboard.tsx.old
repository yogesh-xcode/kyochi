// ── SUB-COMPONENTS ────────────────────────────────────────────

function Avatar({ initials, size = "md", gold = false }) {
  const sizes = { sm: { wh: 32, fs: 11 }, md: { wh: 40, fs: 13 }, lg: { wh: 48, fs: 16 } };
  const s = sizes[size];
  return (
    <div
      style={{
        width: s.wh,
        height: s.wh,
        borderRadius: "50%",
        background: T.cream200,
        border: `2px solid ${gold ? T.gold400 : T.border}`,
        display: "flex",
        alignItems: "center",
        justifyContent: "center",
        fontSize: s.fs,
        fontWeight: 800,
        color: T.gold700,
        flexShrink: 0,
        letterSpacing: "0.02em",
      }}
    >
      {initials}
    </div>
  );
}

function Badge({ children, tone = "gold" }) {
  const styles = {
    gold: { bg: "rgba(212,175,53,0.12)", color: T.gold700, border: "rgba(212,175,53,0.3)" },
    positive: { bg: T.green50, color: T.green700, border: "rgba(63,160,96,0.3)" },
    negative: { bg: T.red50, color: T.red600, border: "rgba(239,68,68,0.3)" },
    muted: { bg: T.cream200, color: T.textMuted, border: T.border },
    session: { bg: "rgba(212,175,53,0.18)", color: T.gold800, border: "rgba(212,175,53,0.4)" },
  };
  const s = styles[tone] || styles.gold;
  return (
    <span
      style={{
        display: "inline-flex",
        alignItems: "center",
        gap: 4,
        fontSize: 11,
        fontWeight: 700,
        padding: "3px 10px",
        borderRadius: 999,
        background: s.bg,
        color: s.color,
        border: `1px solid ${s.border}`,
        whiteSpace: "nowrap",
      }}
    >
      {children}
    </span>
  );
}

function ProgressBar({ value, color = T.gold400, color2 = T.gold300, height = 6 }) {
  return (
    <div
      style={{
        width: "100%",
        height,
        background: T.cream300,
        borderRadius: 999,
        overflow: "hidden",
      }}
    >
      <div
        style={{
          width: `${value}%`,
          height: "100%",
          background: `linear-gradient(90deg, ${color}, ${color2})`,
          borderRadius: 999,
          transition: "width 0.6s ease",
        }}
      />
    </div>
  );
}

function DotIndicator({ tone }) {
  const colors = { positive: T.green400, negative: T.red400, neutral: T.gold400 };
  return (
    <div
      style={{
        width: 9,
        height: 9,
        borderRadius: "50%",
        background: colors[tone] || T.gold400,
        flexShrink: 0,
        boxShadow: `0 0 0 3px ${colors[tone] || T.gold400}22`,
      }}
    />
  );
}

function Card({ children, style = {}, gold = false }) {
  return (
    <div
      style={{
        background: T.surface,
        border: `1px solid ${gold ? "rgba(212,175,53,0.35)" : T.border}`,
        borderRadius: 20,
        boxShadow: gold ? T.shadowGold : T.shadowSm,
        overflow: "hidden",
        ...style,
      }}
    >
      {children}
    </div>
  );
}

function SectionLabel({ children }) {
  return (
    <p
      style={{
        fontSize: 10,
        fontWeight: 700,
        letterSpacing: "0.1em",
        textTransform: "uppercase",
        color: "rgba(212,175,53,0.55)",
        padding: "16px 16px 6px",
      }}
    >
      {children}
    </p>
  );
}

function NavItem({ icon: Icon, label, active }) {
  return (
    <button
      style={{
        display: "flex",
        alignItems: "center",
        gap: 10,
        width: "100%",
        padding: "9px 14px",
        borderRadius: 12,
        border: "none",
        cursor: "pointer",
        fontSize: 13,
        fontWeight: 600,
        textAlign: "left",
        background: active ? "rgba(212,175,53,0.16)" : "transparent",
        color: active ? T.gold300 : "rgba(253,248,231,0.65)",
        transition: "all 0.15s ease",
      }}
    >
      <Icon size={15} style={{ flexShrink: 0 }} />
      {label}
    </button>
  );
}

function ScoreCard({ label, value, delta, tone, icon: Icon, sub }) {
  const isPos = tone === "positive";
  return (
    <Card>
      <div style={{ padding: "22px 24px", position: "relative" }}>
        {/* Icon chip */}
        <div
          style={{
            position: "absolute",
            top: 20,
            right: 20,
            width: 36,
            height: 36,
            borderRadius: 10,
            background: isPos ? "rgba(212,175,53,0.1)" : "rgba(239,68,68,0.08)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            color: isPos ? T.gold500 : T.red400,
          }}
        >
          <Icon size={16} />
        </div>

        <p
          style={{
            fontSize: 10,
            fontWeight: 700,
            letterSpacing: "0.09em",
            textTransform: "uppercase",
            color: T.textFaint,
            marginBottom: 10,
          }}
        >
          {label}
        </p>
        <p
          style={{
            fontSize: 30,
            fontWeight: 800,
            color: T.text,
            letterSpacing: "-0.03em",
            lineHeight: 1,
            marginBottom: 8,
          }}
        >
          {value}
        </p>
        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
          <span
            style={{
              fontSize: 11,
              fontWeight: 700,
              color: isPos ? T.green400 : T.red400,
            }}
          >
            {isPos ? "▲" : "▼"} {delta}
          </span>
          <span style={{ fontSize: 11, color: T.textFaint }}>{sub}</span>
        </div>
      </div>
    </Card>
  );
}

function WellnessRing({ value, max = 10, color, label, size = 72 }) {
  const r = 28;
  const circ = 2 * Math.PI * r;
  const pct = value / max;
  const offset = circ * (1 - pct);
  return (
    <div style={{ textAlign: "center" }}>
      <div style={{ position: "relative", width: size, height: size, margin: "0 auto" }}>
        <svg width={size} height={size} viewBox="0 0 72 72" style={{ transform: "rotate(-90deg)" }}>
          <circle cx="36" cy="36" r={r} fill="none" stroke={T.cream300} strokeWidth="7" />
          <circle
            cx="36"
            cy="36"
            r={r}
            fill="none"
            stroke={color}
            strokeWidth="7"
            strokeDasharray={circ}
            strokeDashoffset={offset}
            strokeLinecap="round"
          />
        </svg>
        <div
          style={{
            position: "absolute",
            inset: 0,
            display: "flex",
            flexDirection: "column",
            alignItems: "center",
            justifyContent: "center",
          }}
        >
          <span style={{ fontSize: 16, fontWeight: 800, color: T.text, lineHeight: 1 }}>
            {value}
          </span>
          <span style={{ fontSize: 8, fontWeight: 700, color: T.textFaint, marginTop: 2 }}>
            {label}
          </span>
        </div>
      </div>
    </div>
  );
}

